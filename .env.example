# --- Server secrets (required in production) ---
# Local dev:
# DATABASE_URL=sqlite:///./data/trade.db
# Turso (remote):
# DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=
# Turso (embedded replica — optional sync URL):
# DATABASE_URL=sqlite+libsql:///./data/trade.db
# TURSO_SYNC_URL=libsql://your-db-name-org.turso.io
DATABASE_URL=sqlite:///./data/trade.db
API_SECRET_KEY=change-me-in-production
ENCRYPTION_KEY=change-me-32-byte-key-for-tokens!!
RECEIVER_BASE_URL=http://localhost:8000
PLATFORM_BASE_URL=http://localhost:3000

# --- Billing ---
LEMON_SQUEEZY_WEBHOOK_SECRET=

# --- Better Auth (platform JWT verification + provisioning) ---
BETTER_AUTH_URL=http://localhost:3000
INTERNAL_API_SECRET=dev-internal-secret

# --- OAuth app registration (your broker developer app, NOT user accounts) ---
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REDIRECT_URI=http://localhost:8000/v1/me/brokers/schwab/callback

TRADIER_CLIENT_ID=
TRADIER_CLIENT_SECRET=
TRADIER_REDIRECT_URI=http://localhost:8000/v1/me/brokers/tradier/callback
TRADIER_OAUTH_SCOPE=read write trade market

# --- Optional ---
TRADIER_API_BASE=https://sandbox.tradier.com/v1
TURSO_AUTH_TOKEN=
TURSO_SYNC_URL=
OPENAI_API_KEY=
ENVIRONMENT=development
CORS_EXTRA_ORIGINS=
LEMON_SQUEEZY_CUSTOMER_PORTAL_URL=
WEBULL_ENABLED=false
