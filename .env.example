# --- Server secrets (required in production) ---
DATABASE_URL=sqlite+libsql:///./data/trade.db
API_SECRET_KEY=change-me-in-production
ENCRYPTION_KEY=change-me-32-byte-key-for-tokens!!
RECEIVER_BASE_URL=http://localhost:8000
PLATFORM_BASE_URL=http://localhost:3000

# --- Billing ---
LEMON_SQUEEZY_WEBHOOK_SECRET=

# --- OAuth app registration (your broker developer app, NOT user accounts) ---
